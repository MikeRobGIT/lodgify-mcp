{
  "mcpServers": {
    "lodgify-mcp": {
      "command": "docker",
      "args": ["exec", "-i", "lodgify-mcp-server", "node", "dist/server.js"],
      "env": {
        "LODGIFY_API_KEY": "${LODGIFY_API_KEY}",
        "LOG_LEVEL": "${LOG_LEVEL:-info}",
        "NODE_ENV": "${NODE_ENV:-production}"
      }
    }
  }
}
